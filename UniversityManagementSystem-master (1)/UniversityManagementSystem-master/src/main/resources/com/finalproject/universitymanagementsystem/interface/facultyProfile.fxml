<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.finalproject.universitymanagementsystem.CellControllers.FacultyProfileController"
      prefHeight="500.0" prefWidth="800.0" spacing="10" alignment="CENTER">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Faculty Profile" style="-fx-font-size: 24px;" />

    <!-- Profile Details Section -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Name:"/>
        <TextField fx:id="nameField" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Email:"/>
        <TextField fx:id="emailField" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Degree:"/>
        <TextField fx:id="degreeField" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Research Interest:"/>
        <TextField fx:id="researchField" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Office Location:"/>
        <TextField fx:id="officeField" prefWidth="300"/>
    </HBox>

    <!-- Courses Offered Section -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Courses Offered:"/>
        <ListView fx:id="coursesListView" prefWidth="300" prefHeight="100" />
    </HBox>

    <!-- Save Button -->
    <Button text="Save Changes" onAction="#saveProfile" prefWidth="200"/>

</VBox>
